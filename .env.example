# Notion integration token.
NOTION_TOKEN=

# Current default API version. Override only if you have a specific reason.
NOTION_API_VERSION=2026-03-11

# Parent page under which the automation will create or locate the database.
NOTION_PARENT_PAGE_ID=

# Database title used for exact-match search and create.
NOTION_DATABASE_TITLE=Q&A Inquiries

# Optional existing IDs. If set, the script prefers these instead of title search.
NOTION_DATABASE_ID=
NOTION_DATA_SOURCE_ID=

# GCP project used to deploy the n8n Cloud Run easy mode service.
GCP_PROJECT_ID=
GCP_REGION=asia-northeast3

# Backend Cloud Run deployment settings.
BACKEND_SERVICE_NAME=qna-backend
BACKEND_IMAGE=
BACKEND_MEMORY=1Gi
BACKEND_VPC_NETWORK=default
BACKEND_VPC_SUBNET=default
BACKEND_VPC_EGRESS=private-ranges-only

# Memorystore for Redis deployment settings.
REDIS_INSTANCE_NAME=qna-redis
REDIS_REGION=asia-northeast3
REDIS_SIZE_GB=1
REDIS_NETWORK=default
REDIS_REDIS_VERSION=redis_7_0

# n8n Cloud Run deployment settings.
N8N_SERVICE_NAME=n8n-demo
N8N_IMAGE=n8nio/n8n:2.13.3
N8N_MEMORY=2Gi
N8N_SCALING=1
N8N_TIMEZONE=Asia/Seoul

# Filled after Cloud Run deployment and one-time owner/API key bootstrap.
N8N_BASE_URL=
N8N_API_KEY=

# Shared secret and workflow-level runtime settings.
N8N_SHARED_SECRET=
N8N_WEBHOOK_REGISTER_PATH=qna-inquiry-register-change-me
N8N_WEBHOOK_COMPLETE_PATH=qna-inquiry-complete-change-me
N8N_FROM_EMAIL=Q&A Bot <change-me@example.com>
N8N_NOTION_CREDENTIAL_NAME=QnA Notion
N8N_SMTP_CREDENTIAL_NAME=QnA SMTP
N8N_NOTION_CREDENTIAL_ID=
N8N_SMTP_CREDENTIAL_ID=
N8N_TEST_ADMIN_EMAIL=
N8N_TEST_REQUESTER_EMAIL=

# SMTP credential values used for the Send Email node.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=true

# FastAPI backend runtime configuration.
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=
ADMIN_JWT_TTL_MINUTES=60
ADMIN_COOKIE_NAME=admin_session
ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_SAMESITE=none
BACKEND_ALLOWED_ORIGINS=http://localhost:3000
BACKEND_CORS_ALLOW_CREDENTIALS=true
REDIS_URL=redis://localhost:6379/0
ADMIN_NOTIFICATION_EMAIL=
BACKEND_BASE_URL=
BACKEND_TEST_REQUESTER_EMAIL=
